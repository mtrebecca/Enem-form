{
  "name": "mtreb/enem-monolito-modular",
  "type": "project",
  "description": "Monolito modular Laravel + React para simulacao de provas ENEM com dados mockados.",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php artisan package:discover --ansi"
    ],
    "test": [
      "@php artisan test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
